{% extends "layouts/main.njk" %}
{% from "components/button/macro.njk" import LBCamdenButton %}

{% set pageTitle = "Check your answers" %}

{% block beforeContent %}
  <div class="govuk-width-container">
    <a href="{{ backHref or '/mental-health-referral/reason-for-referral' }}" class="govuk-back-link">Back</a>
  </div>
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-m">Page 30 of 32</span>
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">Check your answers</h1>

        {% for section in sections %}
          <h2 class="govuk-heading-m{% if not loop.first %} govuk-!-margin-top-6{% endif %}">{{ section.title }}</h2>

          <dl class="govuk-summary-list">
            {% for row in section.rows %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">{{ row.key }}</dt>
                <dd class="govuk-summary-list__value">
                  {% for value in row.values %}
                    {{ value }}{% if not loop.last %}<br>{% endif %}
                  {% endfor %}
                </dd>
                <dd class="govuk-summary-list__actions">
                  <a class="govuk-link" href="{{ row.href }}">Change<span class="govuk-visually-hidden"> {{ row.key | lower }}</span></a>
                </dd>
              </div>
            {% endfor %}
          </dl>
        {% endfor %}

        <form action="/mental-health-referral/check-answers" method="post">
          {{ LBCamdenButton({
            text: "Submit referral",
            preventDoubleClick: true
          }) }}
        </form>
      </div>
    </div>
  </div>
{% endblock %}
