{% extends "layouts/main.njk" %}
{% from "components/button/macro.njk" import LBCamdenButton %}

{% set pageTitle = "Refer someone for mental health social care support" %}

{% block beforeContent %}
  <div class="govuk-width-container">
    <a href="/mental-health-referral/start" class="govuk-back-link">Back</a>
  </div>
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-m">Page 1 of {{ totalPages or 33 }}</span>
        <h1 class="govuk-heading-xl">Refer someone for mental health social care support</h1>

        <p class="govuk-body">This is for professionals to refer someone with a primary mental health need for mental health social care.</p>

        <p class="govuk-body">Do not use this form if you have safeguarding concerns, such as abuse or neglect. Instead, call <a class="govuk-link" href="tel:02079744444">020 7974 4444</a> and when prompted say "Safeguarding". You can also <a class="govuk-link" href="https://www.camden.gov.uk/safeguarding-adults#qubd">report suspected abuse online</a>.</p>

        <p class="govuk-body">For medical emergencies, psychiatric crisis or medication reviews, use the <a class="govuk-link" href="https://www.northlondonmentalhealth.nhs.uk/crisis-referrals-/">North London Foundation Trust (NLFT) crisis line</a> or call 999.</p>

        <p class="govuk-body">This form will take about 20 minutes to complete.</p>

        <p class="govuk-body">It will close after 1 hour of inactivity and your answers will not be saved. This is to protect your information. If the form closes, you will need to start it again.</p>

        {{ LBCamdenButton({
          text: "Start",
          href: "/mental-health-referral/mental-health-conditions-check",
          isStartButton: true
        }) }}
      </div>
    </div>
  </div>
{% endblock %}
